# UniPredict AI Environment Configuration
# Copy this file to .env and update the values for your environment

# Security Settings
UNIPREDICT_SECRET_KEY=your-super-secret-key-here-min-32-chars
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Session Settings
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# Email Configuration (Optional - can be configured via admin panel)
EMAIL_ENABLED=False
EMAIL_PROVIDER=gmail
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USE_SSL=True
EMAIL_SENDER_ADDRESS=your-email@gmail.com
EMAIL_SENDER_PASSWORD=your-app-password
EMAIL_SENDER_NAME=UniPredict AI
EMAIL_REPLY_TO=

# Database Settings (CSV-based - no configuration needed)
# DATA_FOLDER=data/

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/unipredict.log

# Performance Settings
CACHE_TIMEOUT=300
MAX_UPLOAD_SIZE=10485760  # 10MB

# Feature Flags
ENABLE_BULK_EMAIL=True
ENABLE_ACTIVITY_LOGGING=True
ENABLE_EXPORT_FEATURE=True
ENABLE_ADVANCED_SEARCH=True

# Development Settings (set to False in production)
ENABLE_PROFILING=False
ENABLE_DEBUG_TOOLBAR=False
